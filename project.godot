; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Hollow Village"
config/description="A dark fantasy story RPG with deep consequence systems"
config/tags=PackedStringArray("2d", "rpg", "story")
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/ui/icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameState="*res://autoloads/game_state.gd"
TimeManager="*res://autoloads/time_manager.gd"
FactionManager="*res://autoloads/faction_manager.gd"
QuestManager="*res://autoloads/quest_manager.gd"
NarrativeEngine="*res://autoloads/narrative_engine.gd"
WorldSimulation="*res://autoloads/world_simulation.gd"
SaveManager="*res://autoloads/save_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
RelationshipManager="*res://autoloads/relationship_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

