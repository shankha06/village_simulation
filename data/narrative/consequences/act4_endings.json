  "ending_modifiers": [
    {
      "id": "famine_modifier",
      "condition": "flag.silo_destroyed == true",
      "applies_to": [
        "ending_exodus",
        "ending_last_stand",
        "ending_scorched_earth"
      ],
      "effects": [
        {
          "set_state": "flag.famine_affected_ending",
          "value": true
        },
        {
          "set_state": "world.ending.survivor_count_modifier",
          "delta": -0.3
        }
      ],
      "narrative_note": "Fewer survivors due to destroyed grain stores. Exodus is harder. Last stand is weaker."
    },
    {
      "id": "truth_known_modifier",
      "condition": "flag.ashworth_confession_heard == true",
      "applies_to": [
        "ending_new_order",
        "ending_dark_price",
        "ending_harmony"
      ],
      "effects": [
        {
          "set_state": "flag.village_knows_full_truth",
          "value": true
        }
      ],
      "narrative_note": "The village knows the full history of the pact. Changes NPC reactions in epilogue."
    },
    {
      "id": "voss_ally_modifier",
      "condition": "flag.voss_spared_in_duel == true AND npc.commander_voss.alive == true",
      "applies_to": [
        "ending_exodus",
        "ending_last_stand",
        "ending_new_order"
      ],
      "effects": [
        {
          "set_state": "flag.voss_is_ending_ally",
          "value": true
        },
        {
          "set_state": "world.ending.military_strength_modifier",
          "delta": 0.4
        }
      ],
      "narrative_note": "Voss provides military support. Exodus has escort. Last stand is stronger. New Order has a leadership candidate."
    },
    {
      "id": "ironmarch_submitted_modifier",
      "condition": "flag.ironmarch_ultimatum_result == 'submitted'",
      "applies_to": [
        "ending_exodus",
        "ending_last_stand"
      ],
      "effects": [
        {
          "set_state": "flag.ironmarch_controls_remnants",
          "value": true
        }
      ],
      "narrative_note": "The Legion claims jurisdiction over Ashvale's refugees. Exodus is under Legion escort \u2014 protective but controlling."
    },
    {
      "id": "ironmarch_defied_modifier",
      "condition": "flag.ironmarch_ultimatum_result == 'defied'",
      "applies_to": [
        "ending_last_stand",
        "ending_scorched_earth"
      ],
      "effects": [
        {
          "set_state": "flag.ironmarch_hostile_in_ending",
          "value": true
        },
        {
          "set_state": "world.ending.military_strength_modifier",
          "delta": -0.3
        }
      ],
      "narrative_note": "The Legion attacks during the last stand. Scorched earth is partly their doing."
    },
    {
      "id": "mercy_path_modifier",
      "condition": "player.moral_vector.mercy >= 60",
      "applies_to": [
        "ending_harmony",
        "ending_exodus",
        "ending_martyr"
      ],
      "effects": [
        {
          "set_state": "flag.mercy_recognized_in_ending",
          "value": true
        }
      ],
      "narrative_note": "NPCs speak of the player's compassion in epilogue. More survivors in exodus. Heartwood is more receptive in harmony."
    },
    {
      "id": "justice_path_modifier",
      "condition": "player.moral_vector.justice >= 60",
      "applies_to": [
        "ending_new_order",
        "ending_dark_price",
        "ending_last_stand"
      ],
      "effects": [
        {
          "set_state": "flag.justice_recognized_in_ending",
          "value": true
        }
      ],
      "narrative_note": "NPCs respect the player's resolve. New Order is more stable. Dark Price is viewed as necessary evil. Last stand is more disciplined."
    },
    {
      "id": "family_truth_modifier",
      "condition": "flag.maren_family_truth_revealed == true",
      "applies_to": [
        "ending_atonement",
        "ending_harmony",
        "ending_dark_price",
        "ending_new_order"
      ],
      "effects": [
        {
          "set_state": "flag.family_truth_affects_ending",
          "value": true
        }
      ],
      "narrative_note": "The family truth between Brother Maren, Old Maren, and Elara has been revealed. Fundamentally alters emotional tone of endings involving sacrifice or reconciliation."
    }
  ]
}