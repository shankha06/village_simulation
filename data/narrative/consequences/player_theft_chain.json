{
  "id": "player_theft_chain",
  "trigger_condition": "flag.player_stole_in_view == true",
  "consequences": [
    {
      "type": "immediate",
      "effects": [
        {
          "type": "conditional",
          "condition": "npc.witness.personality.courage > 0.5",
          "if_true": [
            {"set_state": "flag.npc_confronts_player_theft", "value": true},
            {"set_state": "npc.witness.memory.caught_player_stealing", "value": true},
            {"set_state": "npc.witness.disposition", "delta": -25}
          ],
          "if_false": [
            {"set_state": "flag.npc_gossips_about_theft", "value": true},
            {"set_state": "npc.witness.memory.saw_player_steal", "value": true},
            {"set_state": "npc.witness.disposition", "delta": -15}
          ]
        }
      ]
    },
    {
      "type": "delayed",
      "delay_days": 1,
      "effects": [
        {"set_state": "flag.theft_reputation_spread", "value": true},
        {"set_state": "world.region.ashvale.player_price_modifier", "delta": 0.25},
        {"broadcast_memory": "heard_player_is_thief", "radius": "village", "value": true}
      ]
    }
  ]
}