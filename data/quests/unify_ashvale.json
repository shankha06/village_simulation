{
  "id": "unify_ashvale",
  "name": "A United Front",
  "description": "To resist the Ironmarch Legion, Ashvale must unite. Every faction distrusts every other, and each has demands before they will stand together. The player must broker impossible alliances \u2014 or accept a weaker defense.",
  "giver": "lord_ashworth",
  "region": "ashvale",
  "tags": [
    "main_quest",
    "act_2",
    "political",
    "alliance",
    "multi_objective"
  ],
  "priority": 14,
  "states": {
    "INACTIVE": {
      "transitions": [
        {
          "on": "flag.defied_legion == true",
          "to": "ACTIVE"
        },
        {
          "on": "flag.draven_killed == true",
          "to": "ACTIVE"
        },
        {
          "on": "flag.negotiated_with_legion == true && flag.planning_resistance == true",
          "to": "ACTIVE"
        }
      ]
    },
    "ACTIVE": {
      "journal_entry": "To resist the Ironmarch Legion, I must unite Ashvale's factions.",
      "objectives": [
        "Secure the Hollow Hand (Fenrick)",
        "Secure the City Guard",
        "Secure the Iron Road Company (Voss)",
        "Secure the Church of Ashen Light",
        "(Optional) Secure the Thornwood Druids"
      ],
      "faction_tracking": {
        "guild": {
          "flag": "flag.guild_joined_defense",
          "conditions_met": [
            {
              "any_of": [
                "flag.sabotage_completed == true",
                "flag.sabotage_abandoned_peacefully == true",
                "flag.fenrick_owes_player == true",
                "flag.blackmailed_fenrick == true"
              ]
            }
          ],
          "effects": [
            {"set_state": "flag.defense_strength_guild", "value": true},
            {"set_state": "world.region.ashvale.defense_score", "delta": 15}
          ]
        },
        "guard": {
          "flag": "flag.guard_joined_defense",
          "conditions_met": [
            {
              "any_of": [
                "flag.found_true_poisoner == true",
                "flag.accused_maren == true",
                "flag.accused_fenrick == true",
                "flag.poisoning_stopped == true"
              ]
            }
          ],
          "effects": [
            {"set_state": "flag.defense_strength_guard", "value": true},
            {"set_state": "world.region.ashvale.defense_score", "delta": 20}
          ]
        },
        "mercs": {
          "flag": "flag.voss_joined_defense",
          "conditions_met": [
            {
              "all_of": [
                "flag.voss_shown_legion_proof == true",
                {
                  "any_of": [
                    "flag.voss_paid_in_gold == true",
                    "flag.voss_offered_land == true",
                    "flag.voss_personal_alliance == true"
                  ]
                }
              ]
            }
          ],
          "effects": [
            {"set_state": "flag.defense_strength_mercs", "value": true},
            {"set_state": "world.region.ashvale.defense_score", "delta": 25}
          ]
        },
        "church": {
          "flag": "flag.church_joined_defense",
          "conditions_met": [
            {
              "any_of": [
                "flag.maren_allied_with_player == true",
                "flag.maren_exposed_and_removed == true",
                "flag.church_congregation_loyal == true"
              ]
            }
          ],
          "effects": [
            {"set_state": "flag.defense_strength_church", "value": true},
            {"set_state": "world.region.ashvale.defense_score", "delta": 10}
          ]
        },
        "druids": {
          "flag": "flag.druids_joined_defense",
          "conditions_met": [
            {
              "all_of": [
                "flag.old_maren_trusts_player == true",
                "flag.forest_investigation_started == true"
              ]
            }
          ],
          "effects": [
            {"set_state": "flag.defense_strength_druids", "value": true},
            {"set_state": "world.region.ashvale.defense_score", "delta": 15},
            {"set_state": "flag.forest_path_opened", "value": true}
          ]
        }
      },
      "transitions": [
        {
          "on": "flag.guild_joined_defense == true AND flag.guard_joined_defense == true AND flag.voss_joined_defense == true AND flag.church_joined_defense == true AND flag.druids_joined_defense == true",
          "to": "FULLY_UNITED"
        },
        {
          "on": "flag.guild_joined_defense == true AND flag.guard_joined_defense == true AND flag.voss_joined_defense == true AND flag.church_joined_defense == true",
          "to": "FULLY_UNITED"
        },
        {
          "on": "flag.ironmarch_deadline_passed == true",
          "to": "PARTIAL_DEFENSE"
        },
        {
          "on": "flag.total_inaction_failure == true",
          "to": "FAILED_TOO_LATE"
        }
      ]
    },
    "FAILED_TOO_LATE": {
      "journal_entry": "I waited too long. The Ironmarch Legion arrived before I could unite anyone. Ashvale faces annihilation alone.",
      "consequence_chain": "total_inaction_chain"
    },
    "FULLY_UNITED": {
      "journal_entry": "Against all odds, Ashvale stands united. Every faction, every grudge, every old wound \u2014 set aside in the face of annihilation. For now. Whether this fragile alliance holds when the real test comes... that remains to be seen.",
      "consequence_chain": "full_unity_chain",
      "effects": [
        {
          "set_state": "flag.ashvale_fully_united",
          "value": true
        },
        {
          "set_state": "world.region.ashvale.defense_score",
          "value": 100
        },
        {
          "set_state": "player.moral_vector",
          "delta": 20
        }
      ]
    },
    "PARTIAL_DEFENSE": {
      "journal_entry": "The deadline has come. Ashvale's defense is incomplete \u2014 some factions refused, others I never reached. We fight with what we have. It may not be enough.",
      "consequence_chain": "partial_defense_chain",
      "effects": [
        {
          "set_state": "flag.ashvale_partial_defense",
          "value": true
        }
      ]
    }
  }
}