[node name="HelpText" type="RichTextLabel" parent="UILayer/HelpOverlay"]
layout_mode = 2
bbcode_enabled = true
text = "[b]THE HOLLOW VILLAGE — Controls[/b]

[color=#dab048]Movement:[/color]  WASD or Arrow Keys
[color=#dab048]Interact:[/color]   E  (talk to NPCs, examine objects)
[color=#dab048]Dodge:[/color]       Space
[color=#dab048]Attack:[/color]      Left Click

[color=#dab048]Inventory:[/color]  I
[color=#dab048]Journal:[/color]     J
[color=#dab048]Quests:[/color]      Q
[color=#dab048]Lore:[/color]         L
[color=#dab048]Map:[/color]          M
[color=#dab048]Cycle tabs:[/color] Tab

[color=#dab048]Tips:[/color]
• Walk near NPCs and objects — look for the [color=#dab048]E[/color] prompt
• Talk to everyone — each NPC knows different secrets
• Examine everything — graves, signs, barrels hide clues
• Your choices have real consequences that unfold over days
• Check your Quest Log [color=#dab048](Q)[/color] for current objectives
• The Lore tab [color=#dab048](L)[/color] tracks discovered mysteries

[i]Press [color=#dab048]H[/color] or [color=#dab048]Esc[/color] to close this help.[/i]"
theme_override_font_sizes/normal_font_size = 11

